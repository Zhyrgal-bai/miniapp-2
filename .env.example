# Copy to .env and fill in. See README deploy notes.
# Обязательно sslmode=require для управляемого Postgres (Render DB, Neon и т.д.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Шифрование Business.botToken в БД (AES-256-GCM). На production/Render обязательно: ≥32 символа случайной строки.
# Локально без ключа токены хранятся plain + botTokenHash (только для dev).
BOT_TOKEN_SECRET_KEY=

# Public HTTPS URL of this API (no trailing slash), e.g. https://api.example.onrender.com.
# Если пусто: для SaaS webhook используется RENDER_EXTERNAL_URL, иначе BASE_URL (fallback по порядку).
API_URL=

# Авто-подписка Finik: платеж создаётся с callback на POST /api/payments/finik-webhook (нужен публичный API_URL).
# Опционально: FINIK_API_BASE_URL, FINIK_API_CREATE_PAYMENT_PATH, FINIK_USE_MOCK, FINIK_WEBHOOK_SIGNATURE_HEADER — см. finikMerchant.ts.
# BASE_URL=
# Обязательно на production/Render: secret_token для setWebhook; Telegram шлёт X-Telegram-Bot-Api-Secret-Token (1–256 символов [A-Za-z0-9_-]).
TELEGRAM_WEBHOOK_SECRET=
# Лимит POST вебхука Telegram с одного IP в секунду (по умолчанию 80).
TELEGRAM_WEBHOOK_MAX_RPS_PER_IP=80
# Только если нужен старый URL /webhook/<числовой_business_id> на переходный период (по умолчанию выкл.).
# TELEGRAM_WEBHOOK_LEGACY_NUMERIC_PATH=1

# SaaS-боты: URL вида POST {API_URL}/webhook/<32_hex из Business.webhookRouteToken>; env-боты: …/telegram-webhook/{index}.

# Telegram bots: several tokens for several stores (same order as BOT_OWNER_IDS / CHAT_IDS).
# Example: BOT_TOKENS=123:AAA,456:BBB
BOT_TOKENS=
# Single-bot legacy (if BOT_TOKENS is empty)
# BOT_TOKEN=

# DB user id владельца магазина i = i-й бот в BOT_TOKENS (для уведомлений и API бота).
BOT_OWNER_IDS=
# Чат админа i-го магазина (опционально, тот же порядок что и токены).
CHAT_IDS=

# Telegram user IDs allowed in admin (comma-separated).
# Регистрация магазина всегда через заявку и ручной approve (Telegram-кнопки или /platform-admin).
ADMIN_IDS=
# Пароль для скрытой панели /admin в регистрационном боте (первый токен из BOT_TOKENS). Используйте длинную случайную строку.
# ADMIN_PANEL_PASSWORD=

# Mini App `/platform` и `/platform-admin`: авторизация по заголовку `x-telegram-init-data` (подпись Telegram WebApp).
# Токен для проверки — первый из BOT_TOKENS / один BOT_TOKEN; если Mini App открыт с другого бота укажите:
# PLATFORM_WEBAPP_BOT_TOKEN=
# Админ-эндпоинты дополнительно проверяют ADMIN_IDS.
# GET /api/platform/admin/businesses; POST /api/platform/admin/disable; POST /api/platform/admin/extend;
# POST /api/platform/admin/purge-business (body: { businessId }) — полное удаление магазина из БД;
# POST /api/platform/admin/block и /unblock (body: { businessId }).

# Лимиты API: общий число запросов с одного IP в минуту под `/api/`, строже для части платформенных POST.
# API_RATE_LIMIT_PER_MIN=60
# API_RATE_LIMIT_STRICT_PER_MIN=10
# Размер JSON-тела: по умолчанию 10kb для API; Telegram/Finik webhook — см. middleware/jsonBodyLimits.ts
# API_JSON_BODY_LIMIT=10kb
# API_JSON_BODY_LIMIT_LARGE=512kb

# Интервал фоновой задачи напоминаний/автоотключения по подписке (мс). По умолчанию 86400000 (24 ч).
# Минимум 60000. См. `runSubscriptionMaintenanceOnce` в src/server/subscriptionMaintenance.ts.
# SUBSCRIPTION_CRON_MS=86400000

# (устарело) SAAS_MANUAL_APPROVAL — авто-создание магазина отключено; переменная игнорируется.
# SAAS_MANUAL_APPROVAL=
# Fallback: один чат для уведомлений, если CHAT_IDS не задан
CHAT_ID=

# Mini App (HTTPS, без финального slash). Приоритет: MINI_APP_URL, затем FRONTEND_URL, FRONT_URL, PUBLIC_URL.
# MINI_APP_URL=
# FRONTEND_URL=
FRONT_URL=
