# Copy to .env and fill in. See README deploy notes.
# Обязательно sslmode=require для управляемого Postgres (Render DB, Neon и т.д.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Public HTTPS URL of this API (no trailing slash), e.g. https://api.example.onrender.com.
# Если пусто: для SaaS webhook используется RENDER_EXTERNAL_URL, иначе BASE_URL (fallback по порядку).
API_URL=

# Авто-подписка Finik: платеж создаётся с callback на POST /api/payments/finik-webhook (нужен публичный API_URL).
# Опционально: FINIK_API_BASE_URL, FINIK_API_CREATE_PAYMENT_PATH, FINIK_USE_MOCK, FINIK_WEBHOOK_SIGNATURE_HEADER — см. finikMerchant.ts.
# BASE_URL=
# Optional: full Telegram webhook URL. If empty, env bots use …/telegram-webhook/{index}; SaaS bots use …/webhook/{businessId}.
# TELEGRAM_WEBHOOK_URL=

# Telegram bots: several tokens for several stores (same order as BOT_OWNER_IDS / CHAT_IDS).
# Example: BOT_TOKENS=123:AAA,456:BBB
BOT_TOKENS=
# Single-bot legacy (if BOT_TOKENS is empty)
# BOT_TOKEN=

# DB user id владельца магазина i = i-й бот в BOT_TOKENS (для уведомлений и API бота).
BOT_OWNER_IDS=
# Чат админа i-го магазина (опционально, тот же порядок что и токены).
CHAT_IDS=

# Telegram user IDs allowed in admin (comma-separated).
# Регистрация магазина всегда через заявку и ручной approve (Telegram-кнопки или /platform-admin).
ADMIN_IDS=
# Пароль для скрытой панели /admin в регистрационном боте (первый токен из BOT_TOKENS). Используйте длинную случайную строку.
# ADMIN_PANEL_PASSWORD=

# Платформа Mini App: единственный админ `/platform-admin` (GET/POST `/api/platform/admin/*`).
# Должен совпадать с VITE_PLATFORM_ADMIN_TELEGRAM_ID во frontend/.env при сборке.
# Доп. маршруты: POST /api/platform/admin/block и /unblock (body: { businessId }).
# PLATFORM_ADMIN_TELEGRAM_ID=

# Интервал фоновой задачи напоминаний/автоотключения по подписке (мс). По умолчанию 86400000 (24 ч).
# Минимум 60000. См. `runSubscriptionMaintenanceOnce` в src/server/subscriptionMaintenance.ts.
# SUBSCRIPTION_CRON_MS=86400000

# (устарело) SAAS_MANUAL_APPROVAL — авто-создание магазина отключено; переменная игнорируется.
# SAAS_MANUAL_APPROVAL=
# Fallback: один чат для уведомлений, если CHAT_IDS не задан
CHAT_ID=

# Mini App (без финального slash). Достаточно одной переменной: FRONTEND_URL или FRONT_URL или PUBLIC_URL.
# FRONTEND_URL=
FRONT_URL=
