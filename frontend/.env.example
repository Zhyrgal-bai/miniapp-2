# Same public API base as server `API_URL` (Vite build embeds at build time).
# Render: задаётся автоматически из RENDER_EXTERNAL_URL (scripts/render-vite-build.mjs).
VITE_API_URL=
# Split deploy (Vercel front + Render API): обязателен, если фронт не на *.onrender.com
# VITE_FALLBACK_API_URL=https://miniapp-2-qipd.onrender.com
VITE_APP_NAME=ARCHA
VITE_FIRST_ORDER_PROMO=ARCHA10
# Optional: Telegram bot link for web landing «Войти через Telegram»
# VITE_ARCHA_TELEGRAM_BOT_URL=https://t.me/archa_kg_bot
# Опционально: те же id, что `ADMIN_IDS`, для локальных экранов (не для гейта /platform-admin).
VITE_ADMIN_IDS=

# `/platform-admin` и платформа: авторизация API через подпись Mini App (`x-telegram-init-data`); ADMIN_IDS только на сервере.
