# Same public API base as server `API_URL` (Vite build embeds this at build time).
VITE_API_URL=
VITE_APP_NAME=Shop
VITE_FIRST_ORDER_PROMO=SHOP10
# Same numeric Telegram user ids as server ADMIN_IDS (comma-separated).
# Needed for Mini App /platform-admin (client gate + x-telegram-id for API).
VITE_ADMIN_IDS=
# Or a single platform admin id (must match server PLATFORM_ADMIN_TELEGRAM_ID).
VITE_PLATFORM_ADMIN_TELEGRAM_ID=

# Server still validates every request; optional legacy PLATFORM_ADMIN_TELEGRAM_ID on API.
