# Same public API base as server `API_URL` (Vite build embeds this at build time).
VITE_API_URL=
VITE_APP_NAME=Shop
VITE_FIRST_ORDER_PROMO=SHOP10
# Comma-separated Telegram user ids for admin UI
VITE_ADMIN_IDS=

# Platform admin (/platform-admin). Must equal server PLATFORM_ADMIN_TELEGRAM_ID (numeric Telegram user id).
# VITE_PLATFORM_ADMIN_TELEGRAM_ID=
