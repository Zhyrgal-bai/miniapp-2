// Multi-tenant SaaS schema — every tenant row scopes by `businessId`
// Queries MUST filter `where: { businessId }` at the tenant boundary.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Tenant (store / SaaS subscriber). One Telegram bot token per tenant.
enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

/// Роль членства в конкретном Business (глобальный User может иметь несколько Membership).
enum MembershipRole {
  OWNER
  ADMIN
  CLIENT
}

/// Optional: explicit plan for Stripe/billing integrations.
enum BillingPlan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

model Business {
  id   Int    @id @default(autoincrement())
  name String

  slug String? @unique

  /// Telegram bot token from @BotFather (one active bot per storefront).
  botToken String @unique

  /// Finik: ключи мерчанта — средства идут клиенту (не на платформу). Не выдавать клиентскому UI в GET.
  finikApiKey  String?
  finikSecret String?

  isActive Boolean @default(true)

  /// Платформа отключила магазин (ручной блок); вебхук игнорируется, витрина недоступна.
  isBlocked Boolean @default(false)

  subscriptionStatus SubscriptionStatus @default(TRIALING)

  billingPlan BillingPlan?

  /// When the configured trial expires (set on onboarding); null if not using trials.
  trialEndsAt DateTime?

  subscriptionEndsAt DateTime?

  /// Last day we sent an expiry reminder (rate-limit: at most one reminder batch per calendar day).
  lastNotifiedAt DateTime?

  /// Витрина: цвета, баннер, logoUrl (JSON). Пустой объект = дефолты на сервере/клиенте.
  themeConfig Json? @default("{}")

  createdAt DateTime @default(now())

  memberships Membership[]
  products    Product[]
  orders      Order[]
  categories  Category[]
  settings    Settings?
  promos      Promo[]
  orderItems  OrderItem[]
  paymentRequests PaymentRequest[]

  @@index([isActive])
  @@index([subscriptionStatus])
  @@index([isBlocked])
}

/// Ручное подтверждение абонемента магазина (скрин/чек в Telegram владельцем).
model PaymentRequest {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  photoUrl   String
  /// 1500 или 5500 если указано у фото (подпись); иначе null — платформа задаёт при approve.
  amountSom  Int?
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([status])
}

/// Глобальная связка Telegram-пользователя (multi-tenant: один аккаунт — несколько Membership).
model User {
  id Int @id @default(autoincrement())

  telegramId String @unique
  name       String?

  memberships Membership[]
  orders      Order[]     @relation("OrderBuyer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Membership {
  id Int @id @default(autoincrement())

  role MembershipRole @default(CLIENT)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, businessId])
  @@index([businessId])
}

/// Storefront + payment display settings per tenant (1:1 with Business).
model Settings {
  id Int @id @default(autoincrement())

  businessId Int      @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  themeColor String?
  logoUrl    String?

  mbank  String?
  optima String?
  other  String?
  card   String?
  qr     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id   Int    @id @default(autoincrement())
  name String

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@unique([businessId, name])
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  price       Int
  description String?

  image  String?
  images String[] @default([])

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]

  @@index([businessId])
  @@index([categoryId])
}

enum OrderStatus {
  NEW
  ACCEPTED
  PAID_PENDING
  CONFIRMED
  SHIPPED
  CANCELLED
}

/// Customer order — always anchored to Business; line items optionally reference Product snapshots.
model Order {
  id     Int       @id @default(autoincrement())
  status OrderStatus @default(NEW)

  /// Buyer display name snapshot (from Telegram / form).
  name    String
  phone   String
  address String

  total Int

  paymentMethod String?

  tracking   String?
  receiptUrl String?
  receiptType String?
  paymentId String?

  lat Float?
  lng Float?

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  /// Optional FK to tenant User (Telegram shopper) — still always filter orders by businessId first.
  buyerUserId Int?
  buyerUser   User?   @relation("OrderBuyer", fields: [buyerUserId], references: [id], onDelete: SetNull)

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([businessId, status])
  @@index([buyerUserId])
}

/// Line item belongs to Order; duplicated `businessId` enables tenant-only deletes / analytics queries without joins.
model OrderItem {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  productId Int?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  name     String
  size     String @default("")
  color    String @default("")
  quantity Int
  price    Int

  @@index([businessId])
  @@index([orderId])
}

/// Promotions scoped per tenant (no global `@unique(code)` across businesses).
enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Incoming merchant signup requests (admin approves → Business + User created).
model RegistrationRequest {
  id         Int                  @id @default(autoincrement())
  name       String
  botToken   String
  phone      String
  telegramId String
  status     RegistrationStatus @default(PENDING)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([status])
  @@index([telegramId])
}

model Promo {
  id       Int @id @default(autoincrement())
  code     String
  discount Int
  maxUses  Int
  used     Int @default(0)

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, code])
  @@index([businessId])
}
