// Multi-tenant SaaS schema — every tenant row scopes by `businessId`
// Queries MUST filter `where: { businessId }` at the tenant boundary.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Tenant (store / SaaS subscriber). One Telegram bot token per tenant.
enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

/// Роль членства в конкретном Business (глобальный User может иметь несколько Membership).
enum MembershipRole {
  OWNER
  ADMIN
  CLIENT
}

/// Optional: explicit plan for Stripe/billing integrations.
enum BillingPlan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

enum BusinessType {
  clothing
  coffee
  fastfood
  flowers
}

model Business {
  id   Int    @id @default(autoincrement())
  name String

  slug String? @unique

  /// Telegram bot: AES-256-GCM (enc:v1:...) или временно plain в локальном dev без ключа.
  botToken String

  /// SHA-256(hex) от plain-токена — уникальность и антидубликаты.
  botTokenHash String @unique

  /// Сегмент URL вебхука Telegram: случайный токен, путь вида webhook/<token>.
  webhookRouteToken String? @unique

  /// Finik: ключи мерчанта — средства идут клиенту (не на платформу). Не выдавать клиентскому UI в GET.
  finikApiKey  String?
  finikSecret String?

  isActive Boolean @default(true)

  /// Платформа отключила магазин (ручной блок); вебхук игнорируется, витрина недоступна.
  isBlocked Boolean @default(false)

  subscriptionStatus SubscriptionStatus @default(TRIALING)

  billingPlan BillingPlan?

  /// When the configured trial expires (set on onboarding); null if not using trials.
  trialEndsAt DateTime?

  subscriptionEndsAt DateTime?

  /// Last day we sent an expiry reminder (rate-limit: at most one reminder batch per calendar day).
  lastNotifiedAt DateTime?

  /// Анти-спам: уже отправили напоминание «за 3 дня» для текущего цикла окончания подписки.
  lastReminder3DaysAt DateTime?

  /// Анти-спам: уже отправили напоминание «за 1 день».
  lastReminder1DayAt DateTime?

  /// Витрина: цвета, баннер, logoUrl (JSON). Пустой объект = дефолты на сервере/клиенте.
  themeConfig Json? @default("{}")

  /// Готовый пресет: red | dark | light | luxury (null = только themeConfig).
  templateId String?

  businessType BusinessType

  merchantConfig Json? @default("{}")

  templateVersion Int @default(1)

  storefrontConfig Json? @default("{}")
  storefrontConfigVersion Int @default(1)
  featureFlags Json? @default("{}")

  /// Visual Storefront Builder (Stage 4): draft/publish configs.
  /// Draft edited in builder; published served to public storefront.
  storefrontDraftConfig Json? @default("{}")
  storefrontPublishedConfig Json? @default("{}")
  storefrontPublishedAt DateTime?
  storefrontDraftUpdatedAt DateTime?

  createdAt DateTime @default(now())

  storefronts Storefront[]
  reusableBlocks StorefrontReusableBlock[]

  memberships Membership[]
  products    Product[]
  orders      Order[]
  categories  Category[]
  settings    Settings?
  promos      Promo[]
  orderItems  OrderItem[]
  paymentRequests PaymentRequest[]

  /// Платежи Finik только за SaaS-подписку (не заказы витрины).
  subscriptionFinikPayments SubscriptionFinikPayment[]

  merchantChangeRequests MerchantChangeRequest[]

  supportTickets  SupportTicket[]
  supportMessages SupportMessage[]
  returnRequests  ReturnRequest[]

  @@index([isActive])
  @@index([subscriptionStatus])
  @@index([isBlocked])
}

model Storefront {
  id Int @id @default(autoincrement())

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  /// Human friendly name for merchant (MVP).
  name String @default("Main")

  /// Optional URL slug for future multi-storefront routing.
  slug String?

  /// Draft edited in builder.
  draftConfig Json @default("{}")

  /// Published served to public storefront.
  publishedConfig Json @default("{}")
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reusableBlocks StorefrontReusableBlock[]

  @@index([businessId])
  @@index([businessId, slug])
}

model StorefrontReusableBlock {
  id Int @id @default(autoincrement())

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  /// Nullable for now: business-scoped blocks; later can be tied to a specific storefront.
  storefrontId Int?
  storefront   Storefront? @relation(fields: [storefrontId], references: [id], onDelete: Cascade)

  type String
  name String
  config Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([storefrontId])
  @@index([businessId, type])
}

/// Ручное подтверждение абонемента магазина (скрин/чек в Telegram владельцем).
model PaymentRequest {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  photoUrl   String
  /// 1500 или 5500 если указано у фото (подпись); иначе null — платформа задаёт при approve.
  amountSom  Int?
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([status])
}

/// Онлайн-оплата подписки через Finik (отдельно от заказов витрины и от PaymentRequest).
model SubscriptionFinikPayment {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  finikPaymentId String? @unique
  planDays       Int
  amountSom      Int
  payerTelegramId String

  /// pending | completed | failed
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([businessId])
  @@index([status])
}

/// Глобальная связка Telegram-пользователя (multi-tenant: один аккаунт — несколько Membership).
model User {
  id Int @id @default(autoincrement())

  telegramId String @unique
  name       String?

  /// После первого выданного trial новые магазины этого аккаунта без trial до оплаты.
  hasUsedTrial Boolean @default(false)

  memberships    Membership[]
  orders         Order[]         @relation("OrderBuyer")
  supportTickets SupportTicket[]
  returnRequests ReturnRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Membership {
  id Int @id @default(autoincrement())

  role MembershipRole @default(CLIENT)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, businessId])
  @@index([businessId])
}

/// Storefront + payment display settings per tenant (1:1 with Business).
model Settings {
  id Int @id @default(autoincrement())

  businessId Int      @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  themeColor String?
  logoUrl    String?

  mbank  String?
  optima String?
  other  String?
  card   String?
  qr     String?

  /// онлайн ККМ: `finik` при регистрации с ключом; полная оплата — отдельная интеграция.
  paymentProvider String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id   Int    @id @default(autoincrement())
  name String

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  parentId Int?
  parent   Category? @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryTree")

  config Json? @default("{}")

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([businessId, parentId])
  @@index([parentId])
  @@unique([businessId, parentId, name])
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  price       Int
  description String?

  image  String?
  images String[] @default([])
  /// New (Stage 6.5): Cloudinary metadata, backwards compatible with `image`/`images`.
  /// Format: [{ url, publicId, width, height }]
  imagesMeta Json? @default("[]")

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  attributes Json? @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]

  @@index([businessId])
  @@index([categoryId])
}

enum OrderStatus {
  NEW
  ACCEPTED
  PAID_PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum SupportTicketStatus {
  OPEN
  PENDING_CUSTOMER
  PENDING_MERCHANT
  RESOLVED
  CLOSED
}

enum SupportTicketType {
  GENERAL
  DELIVERY
  QUALITY
  RETURN
  EXCHANGE
  CANCEL_REQUEST
  ADDRESS_CHANGE
  TRACKING
  OTHER
}

enum SupportSenderType {
  CUSTOMER
  MERCHANT
  SYSTEM
}

enum ReturnRequestStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  RETURNED
}

enum ReturnReason {
  SIZE
  DAMAGE
  WRONG_ITEM
  QUALITY
  OTHER
}

/// Customer order — always anchored to Business; line items optionally reference Product snapshots.
model Order {
  id     Int       @id @default(autoincrement())
  status OrderStatus @default(NEW)

  /// Buyer display name snapshot (from Telegram / form).
  name    String
  phone   String
  address String

  total Int

  paymentMethod String?

  tracking   String?
  receiptUrl String?
  receiptType String?
  paymentId String?

  lat Float?
  lng Float?

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  /// Optional FK to tenant User (Telegram shopper) — still always filter orders by businessId first.
  buyerUserId Int?
  buyerUser   User?   @relation("OrderBuyer", fields: [buyerUserId], references: [id], onDelete: SetNull)

  items            OrderItem[]
  supportTickets   SupportTicket[]
  returnRequests   ReturnRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([businessId, status])
  @@index([buyerUserId])
}

/// Line item belongs to Order; duplicated `businessId` enables tenant-only deletes / analytics queries without joins.
model OrderItem {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  productId Int?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  name     String
  size     String @default("")
  color    String @default("")
  quantity Int
  price    Int

  options Json? @default("{}")

  returnRequests ReturnRequest[]

  @@index([businessId])
  @@index([orderId])
}

model SupportTicket {
  id           Int                 @id @default(autoincrement())
  businessId   Int
  business     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId       Int
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId      Int
  order        Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status       SupportTicketStatus @default(OPEN)
  type         SupportTicketType   @default(GENERAL)
  priority     Int                 @default(0)
  internalNote String?
  messages     SupportMessage[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([businessId, status])
  @@index([businessId, orderId])
  @@index([orderId])
}

model SupportMessage {
  id           Int               @id @default(autoincrement())
  ticketId     Int
  ticket       SupportTicket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  businessId   Int
  business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  senderType   SupportSenderType
  senderId     Int?
  text         String            @default("")
  attachments  Json              @default("[]")
  createdAt    DateTime          @default(now())

  @@index([businessId, ticketId])
}

model ReturnRequest {
  id           Int                 @id @default(autoincrement())
  businessId   Int
  business     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orderId      Int
  order        Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId       Int
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItemId  Int?
  orderItem    OrderItem?          @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  reason       ReturnReason
  status       ReturnRequestStatus @default(PENDING)
  photos       Json                @default("[]")
  refundAmount Int?
  comment      String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([businessId, status])
  @@index([orderId])
}

/// Promotions scoped per tenant (no global `@unique(code)` across businesses).
enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Журнал опасных действий суперадмина рег-бота (без секретов).
enum AdminActionType {
  DELETE_SHOP
  EXTEND_SUBSCRIPTION
}

model AdminActionLog {
  id                Int             @id @default(autoincrement())
  adminTelegramId   String
  action            AdminActionType
  targetBusinessId  Int
  details           Json            @default("{}")
  createdAt         DateTime        @default(now())

  @@index([adminTelegramId])
  @@index([targetBusinessId])
  @@index([createdAt])
}

/// Заявки на изменение магазина (сейчас только смена botToken — после approve).
model MerchantChangeRequest {
  id Int @id @default(autoincrement())

  /// Пока только BOT_TOKEN_CHANGE.
  type String @default("BOT_TOKEN_CHANGE")

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  newBotToken           String
  requesterTelegramId   String

  /// PENDING | APPROVED | REJECTED
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([businessId])
}

/// Incoming merchant signup requests (admin approves → Business + User created).
model RegistrationRequest {
  id         Int                  @id @default(autoincrement())
  name       String
  botToken   String
  phone      String

  /// Finik (онлайн ККМ), подставляется в Business.finikApiKey после approve.
  finikApiKey String?

  businessType BusinessType

  telegramId String
  status     RegistrationStatus @default(PENDING)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([status])
  @@index([telegramId])
}

model Promo {
  id       Int @id @default(autoincrement())
  code     String
  discount Int
  maxUses  Int
  used     Int @default(0)

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, code])
  @@index([businessId])
}
