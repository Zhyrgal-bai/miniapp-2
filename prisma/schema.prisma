// Multi-tenant SaaS schema — every tenant row scopes by `businessId`
// Queries MUST filter `where: { businessId }` at the tenant boundary.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Tenant (store / SaaS subscriber). One Telegram bot token per tenant.
enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

/// Роль членства в конкретном Business (глобальный User может иметь несколько Membership).
enum MembershipRole {
  OWNER
  ADMIN
  CLIENT
}

/// Optional: explicit plan for Stripe/billing integrations.
enum BillingPlan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

enum BusinessType {
  clothing
  coffee
  fastfood
  flowers
}

model Business {
  id   Int    @id @default(autoincrement())
  name String

  slug String? @unique

  /// Telegram bot: AES-256-GCM (enc:v1:...) или временно plain в локальном dev без ключа.
  botToken String

  /// SHA-256(hex) от plain-токена — уникальность и антидубликаты.
  botTokenHash String @unique

  /// Сегмент URL вебхука Telegram: случайный токен, путь вида webhook/<token>.
  webhookRouteToken String? @unique

  /// Finik: ключи мерчанта — средства идут клиенту (не на платформу). Не выдавать клиентскому UI в GET.
  finikApiKey  String?
  finikSecret String?

  isActive Boolean @default(true)

  /// Платформа отключила магазин (ручной блок); вебхук игнорируется, витрина недоступна.
  isBlocked Boolean @default(false)

  subscriptionStatus SubscriptionStatus @default(TRIALING)

  billingPlan BillingPlan?

  /// When the configured trial expires (set on onboarding); null if not using trials.
  trialEndsAt DateTime?

  subscriptionEndsAt DateTime?

  /// Last day we sent an expiry reminder (rate-limit: at most one reminder batch per calendar day).
  lastNotifiedAt DateTime?

  /// Анти-спам: уже отправили напоминание «за 3 дня» для текущего цикла окончания подписки.
  lastReminder3DaysAt DateTime?

  /// Анти-спам: уже отправили напоминание «за 1 день».
  lastReminder1DayAt DateTime?

  /// Витрина: цвета, баннер, logoUrl (JSON). Пустой объект = дефолты на сервере/клиенте.
  themeConfig Json? @default("{}")

  /// Готовый пресет: red | dark | light | luxury (null = только themeConfig).
  templateId String?

  businessType BusinessType

  merchantConfig Json? @default("{}")

  templateVersion Int @default(1)

  storefrontConfig Json? @default("{}")
  storefrontConfigVersion Int @default(1)
  featureFlags Json? @default("{}")

  /// Visual Storefront Builder (Stage 4): draft/publish configs.
  /// Draft edited in builder; published served to public storefront.
  storefrontDraftConfig Json? @default("{}")
  storefrontPublishedConfig Json? @default("{}")
  storefrontPublishedAt DateTime?
  storefrontDraftUpdatedAt DateTime?

  createdAt DateTime @default(now())

  storefronts Storefront[]
  reusableBlocks StorefrontReusableBlock[]

  memberships Membership[]
  products    Product[]
  orders      Order[]
  categories  Category[]
  settings    Settings?
  promos      Promo[]
  orderItems  OrderItem[]
  paymentRequests PaymentRequest[]
  dailyOrderCounters BusinessDailyOrderCounter[]

  /// Платежи Finik только за SaaS-подписку (не заказы витрины).
  subscriptionFinikPayments SubscriptionFinikPayment[]

  merchantChangeRequests MerchantChangeRequest[]

  supportTickets  SupportTicket[]
  supportMessages SupportMessage[]
  returnRequests  ReturnRequest[]
  cancelRequests  CancelRequest[]
  refundRequests  RefundRequest[]
  productStocks   ProductStock[]
  stockMovements  StockMovement[]
  actionCooldowns ActionCooldown[]

  storefrontEvents StorefrontEvent[]
  merchantNotifications MerchantNotification[]
  automationRules AutomationRule[]
  platformListing PlatformStoreListing?
  referralCode MerchantReferralCode?

  @@index([isActive])
  @@index([subscriptionStatus])
  @@index([isBlocked])
}

model Storefront {
  id Int @id @default(autoincrement())

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  /// Human friendly name for merchant (MVP).
  name String @default("Main")

  /// Optional URL slug for future multi-storefront routing.
  slug String?

  /// Draft edited in builder.
  draftConfig Json @default("{}")

  /// Published served to public storefront.
  publishedConfig Json @default("{}")
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reusableBlocks StorefrontReusableBlock[]

  @@index([businessId])
  @@index([businessId, slug])
}

model StorefrontReusableBlock {
  id Int @id @default(autoincrement())

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  /// Nullable for now: business-scoped blocks; later can be tied to a specific storefront.
  storefrontId Int?
  storefront   Storefront? @relation(fields: [storefrontId], references: [id], onDelete: Cascade)

  type String
  name String
  config Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([storefrontId])
  @@index([businessId, type])
}

/// Ручное подтверждение абонемента магазина (скрин/чек в Telegram владельцем).
model PaymentRequest {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  photoUrl   String
  /// 1500 или 5500 если указано у фото (подпись); иначе null — платформа задаёт при approve.
  amountSom  Int?
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([status])
}

/// Онлайн-оплата подписки через Finik (отдельно от заказов витрины и от PaymentRequest).
model SubscriptionFinikPayment {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  finikPaymentId String? @unique
  planDays       Int
  amountSom      Int
  payerTelegramId String

  /// pending | completed | failed
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([businessId])
  @@index([status])
}

/// Глобальная связка Telegram-пользователя (multi-tenant: один аккаунт — несколько Membership).
model User {
  id Int @id @default(autoincrement())

  telegramId String @unique
  name       String?

  /// После первого выданного trial новые магазины этого аккаунта без trial до оплаты.
  hasUsedTrial Boolean @default(false)

  memberships    Membership[]
  orders         Order[]         @relation("OrderBuyer")
  supportTickets SupportTicket[]
  returnRequests ReturnRequest[]
  cancelRequests CancelRequest[]
  refundRequests RefundRequest[]
  actionCooldowns ActionCooldown[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Membership {
  id Int @id @default(autoincrement())

  role MembershipRole @default(CLIENT)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  /// Гранулярные права для ADMIN (OWNER игнорирует список на сервере).
  permissions String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, businessId])
  @@index([businessId])
}

/// Storefront + payment display settings per tenant (1:1 with Business).
model Settings {
  id Int @id @default(autoincrement())

  businessId Int      @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  themeColor String?
  logoUrl    String?

  mbank  String?
  optima String?
  other  String?
  card   String?
  qr     String?

  /// онлайн ККМ: `finik` при регистрации с ключом; полная оплата — отдельная интеграция.
  paymentProvider String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id   Int    @id @default(autoincrement())
  name String

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  parentId Int?
  parent   Category? @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryTree")

  config Json? @default("{}")

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([businessId, parentId])
  @@index([parentId])
  @@unique([businessId, parentId, name])
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  price       Int
  description String?

  image  String?
  images String[] @default([])
  /// New (Stage 6.5): Cloudinary metadata, backwards compatible with `image`/`images`.
  /// Format: [{ url, publicId, width, height }]
  imagesMeta Json? @default("[]")

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  attributes Json? @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]
  stocks     ProductStock[]

  @@index([businessId])
  @@index([categoryId])
}

enum OrderStatus {
  NEW
  ACCEPTED
  PAID_PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum SupportTicketStatus {
  OPEN
  PENDING_CUSTOMER
  PENDING_MERCHANT
  RESOLVED
  CLOSED
}

enum SupportTicketType {
  GENERAL
  DELIVERY
  QUALITY
  RETURN
  EXCHANGE
  CANCEL_REQUEST
  ADDRESS_CHANGE
  TRACKING
  OTHER
}

enum SupportSenderType {
  CUSTOMER
  MERCHANT
  SYSTEM
}

enum ReturnRequestStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  RETURNED
}

enum ReturnReason {
  SIZE
  DAMAGE
  WRONG_ITEM
  QUALITY
  OTHER
}

enum CancelRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RefundRequestStatus {
  REQUESTED
  REVIEWING
  APPROVED
  REJECTED
  REFUNDED
}

enum DeliveryMode {
  PICKUP
  DELIVERY
}

enum DeliveryStage {
  PREPARING
  COURIER_DISPATCHED
  OUT_FOR_DELIVERY
  NEARBY
  DELIVERED
}

enum StockMovementKind {
  RESERVE
  RELEASE
  COMMIT_PAID
  RESTORE_PAID
  SHIP
  RETURN_RECEIVED
  RESTOCK
  ADJUST
}

/// Customer order — always anchored to Business; line items optionally reference Product snapshots.
model Order {
  id     Int       @id @default(autoincrement())
  status OrderStatus @default(NEW)

  /// Human-friendly per-business daily number, e.g. 2105-001 (DDMM-seq).
  orderNumber String?

  /// Buyer display name snapshot (from Telegram / form).
  name    String
  phone   String
  address String

  total Int

  paymentMethod String?

  tracking   String?
  receiptUrl String?
  receiptType String?
  paymentId String?

  lat Float?
  lng Float?

  deliveryMode DeliveryMode @default(DELIVERY)
  preparationMinutes Int?
  estimatedDeliveryAt DateTime?
  deliveryStage DeliveryStage?

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  /// Optional FK to tenant User (Telegram shopper) — still always filter orders by businessId first.
  buyerUserId Int?
  buyerUser   User?   @relation("OrderBuyer", fields: [buyerUserId], references: [id], onDelete: SetNull)

  items            OrderItem[]
  supportTickets   SupportTicket[]
  returnRequests   ReturnRequest[]
  cancelRequests   CancelRequest[]
  refundRequests   RefundRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, orderNumber])
  @@index([buyerUserId])
}

/// Per-tenant daily order sequence (resets each calendar day in ORDER_DAY_TZ).
model BusinessDailyOrderCounter {
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  /// DDMM key, e.g. "2105" for 21 May.
  dayKey  String
  lastSeq Int    @default(0)

  @@id([businessId, dayKey])
  @@index([businessId])
}

/// Line item belongs to Order; duplicated `businessId` enables tenant-only deletes / analytics queries without joins.
model OrderItem {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  productId Int?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  name     String
  size     String @default("")
  color    String @default("")
  quantity Int
  price    Int

  options Json? @default("{}")

  returnRequests ReturnRequest[]

  @@index([businessId])
  @@index([orderId])
}

model SupportTicket {
  id           Int                 @id @default(autoincrement())
  businessId   Int
  business     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId       Int
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId      Int
  order        Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status       SupportTicketStatus @default(OPEN)
  type         SupportTicketType   @default(GENERAL)
  priority     Int                 @default(0)
  internalNote String?
  messages     SupportMessage[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([businessId, status])
  @@index([businessId, orderId])
  @@index([orderId])
}

model SupportMessage {
  id           Int               @id @default(autoincrement())
  ticketId     Int
  ticket       SupportTicket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  businessId   Int
  business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  senderType   SupportSenderType
  senderId     Int?
  text         String            @default("")
  attachments  Json              @default("[]")
  createdAt    DateTime          @default(now())

  @@index([businessId, ticketId])
}

model ReturnRequest {
  id           Int                 @id @default(autoincrement())
  businessId   Int
  business     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orderId      Int
  order        Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId       Int
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItemId  Int?
  orderItem    OrderItem?          @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  reason       ReturnReason
  status       ReturnRequestStatus @default(PENDING)
  photos       Json                @default("[]")
  refundAmount Int?
  comment      String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([businessId, status])
  @@index([orderId])
}

model CancelRequest {
  id              Int                 @id @default(autoincrement())
  businessId      Int
  business        Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orderId         Int
  order           Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId          Int
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason          String?
  comment         String?
  merchantComment String?
  status          CancelRequestStatus @default(PENDING)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([businessId, status])
  @@index([orderId])
}

model RefundRequest {
  id              Int                 @id @default(autoincrement())
  businessId      Int
  business        Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orderId         Int
  order           Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId          Int
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason          String?
  comment         String?
  merchantComment String?
  refundAmount    Int?
  status          RefundRequestStatus @default(REQUESTED)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([businessId, status])
  @@index([orderId])
}

/// Promotions scoped per tenant (no global `@unique(code)` across businesses).
enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Журнал опасных действий суперадмина рег-бота (без секретов).
enum AdminActionType {
  DELETE_SHOP
  EXTEND_SUBSCRIPTION
}

model AdminActionLog {
  id                Int             @id @default(autoincrement())
  adminTelegramId   String
  action            AdminActionType
  targetBusinessId  Int
  details           Json            @default("{}")
  createdAt         DateTime        @default(now())

  @@index([adminTelegramId])
  @@index([targetBusinessId])
  @@index([createdAt])
}

model PlatformOperatorSession {
  id                Int      @id @default(autoincrement())
  operatorTelegramId String
  tokenHash         String   @unique
  userAgent         String?
  ipHash            String?
  createdAt         DateTime @default(now())
  lastActivityAt    DateTime @default(now())
  expiresAt         DateTime
  lastReauthAt      DateTime?
  revokedAt         DateTime?

  @@index([operatorTelegramId])
  @@index([expiresAt])
  @@index([revokedAt])
}

/// Заявки на изменение магазина (сейчас только смена botToken — после approve).
model MerchantChangeRequest {
  id Int @id @default(autoincrement())

  /// Пока только BOT_TOKEN_CHANGE.
  type String @default("BOT_TOKEN_CHANGE")

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  newBotToken           String
  requesterTelegramId   String

  /// PENDING | APPROVED | REJECTED
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([businessId])
}

/// Incoming merchant signup requests (admin approves → Business + User created).
model RegistrationRequest {
  id         Int                  @id @default(autoincrement())
  name       String
  botToken   String
  phone      String

  /// Finik (онлайн ККМ), подставляется в Business.finikApiKey после approve.
  finikApiKey String?

  businessType BusinessType

  telegramId String
  /// Telegram @username без @ (если есть).
  ownerUsername String?
  /// @username бота мерчанта (из getMe при submit).
  botUsername   String?
  rejectReason  String?

  status     RegistrationStatus @default(PENDING)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([status])
  @@index([telegramId])
}

model Promo {
  id       Int @id @default(autoincrement())
  code     String
  discount Int
  maxUses  Int
  used     Int @default(0)

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, code])
  @@index([businessId])
}

/// Storefront engagement events for audience & conversion analytics.
enum StorefrontEventType {
  STORE_VIEW
  PRODUCT_VIEW
  ADD_TO_CART
  CHECKOUT_START
}

model StorefrontEvent {
  id         Int                 @id @default(autoincrement())
  businessId Int
  business   Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  eventType  StorefrontEventType
  /// Anonymous visitor fingerprint (hashed telegram id or session id).
  visitorKey String
  userId     Int?
  productId  Int?
  meta       Json                @default("{}")

  createdAt DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([businessId, eventType, createdAt])
  @@index([businessId, visitorKey])
}

/// In-app merchant notification center (per tenant).
enum MerchantNotificationKind {
  ORDER_NEW
  ORDER_STATUS
  SUPPORT_MESSAGE
  SUPPORT_TICKET
  PAYMENT_ISSUE
  DELIVERY_UPDATE
  REFUND_REQUEST
  CANCEL_REQUEST
  RETURN_REQUEST
  LOW_STOCK
  SUBSCRIPTION_EXPIRING
  WEBHOOK_FAILED
  SYSTEM
}

model MerchantNotification {
  id         Int                      @id @default(autoincrement())
  businessId Int
  business   Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  kind       MerchantNotificationKind
  title      String
  body       String?
  href       String?
  readAt     DateTime?

  createdAt DateTime @default(now())

  @@index([businessId, readAt])
  @@index([businessId, createdAt])
}

/// Merchant automation rules foundation (Phase 1 — schema only; runner Phase 2).
enum AutomationRuleStatus {
  ACTIVE
  PAUSED
}

model AutomationRule {
  id         Int                  @id @default(autoincrement())
  businessId Int
  business   Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  /// Built-in rule id, e.g. conversion_low_alert
  ruleKey    String
  name       String
  status     AutomationRuleStatus @default(ACTIVE)
  config     Json                 @default("{}")
  lastRunAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, ruleKey])
  @@index([businessId, status])
}

/// Onboarding & product validation funnel (beta / release metrics).
model PlatformFunnelEvent {
  id         Int      @id @default(autoincrement())
  step       String
  telegramId String?
  businessId Int?
  meta       Json     @default("{}")

  createdAt DateTime @default(now())

  @@index([step, createdAt])
  @@index([telegramId, createdAt])
  @@index([businessId, createdAt])
}

/// Beta / release feedback from merchants and shoppers.
model ProductFeedback {
  id         Int      @id @default(autoincrement())
  kind       String
  message    String
  telegramId String?
  businessId Int?
  page       String?
  meta       Json     @default("{}")
  status     String   @default("open")

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([businessId, createdAt])
}

/// Public marketplace directory entry (opt-in visibility).
model PlatformStoreListing {
  businessId   Int          @id
  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  slug         String       @unique
  displayName  String
  tagline      String?
  logoUrl      String?
  businessType BusinessType
  isPublic     Boolean      @default(false)
  isFeatured   Boolean      @default(false)
  featuredRank Int?
  trendScore   Int          @default(0)
  delistedAt   DateTime?
  publishedAt  DateTime?

  updatedAt DateTime @updatedAt

  @@index([isPublic, isFeatured])
  @@index([businessType, isPublic])
  @@index([trendScore])
}

/// Merchant-to-merchant referral code.
model MerchantReferralCode {
  id         Int      @id @default(autoincrement())
  businessId Int      @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  code       String   @unique
  signups    Int      @default(0)

  createdAt DateTime @default(now())
  signupsLog MerchantReferralSignup[]

  @@index([code])
}

model MerchantReferralSignup {
  id                    Int                  @id @default(autoincrement())
  referralCodeId        Int
  referralCode          MerchantReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  referrerBusinessId    Int
  applicantTelegramId   String
  registrationRequestId Int?

  createdAt DateTime @default(now())

  @@index([referrerBusinessId, createdAt])
  @@index([applicantTelegramId])
}

/// Per-SKU operational inventory (available / reserved / paid / shipped / returned).
model ProductStock {
  id Int @id @default(autoincrement())

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  size  String @default("")
  color String @default("")
  /// Normalized key: `${size}|${color}` lowercased.
  variantKey String

  available Int @default(0)
  reserved  Int @default(0)
  paid      Int @default(0)
  shipped   Int @default(0)
  returned  Int @default(0)

  movements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, productId, variantKey])
  @@index([businessId, productId])
}

model StockMovement {
  id Int @id @default(autoincrement())

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  productStockId Int
  productStock   ProductStock @relation(fields: [productStockId], references: [id], onDelete: Cascade)

  orderId     Int?
  orderItemId Int?
  kind        StockMovementKind
  quantity    Int
  meta        Json? @default("{}")

  createdAt DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([productStockId])
  @@index([orderId])
}

/// Anti-abuse cooldowns (checkout spam, support flood).
model ActionCooldown {
  id Int @id @default(autoincrement())

  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  actionKey String
  lastAt    DateTime @default(now())

  @@unique([businessId, userId, actionKey])
  @@index([businessId, actionKey])
}
